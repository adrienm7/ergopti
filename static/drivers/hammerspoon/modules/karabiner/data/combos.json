{
    "description": "Special key combos and Cmd+Shift remaps",
    "manipulators": [
        {
            "description": "Left Option + É (z): Cmd+Shift+C",
            "type": "basic",
            "from": {
                "key_code": "z",
                "modifiers": { "mandatory": ["left_option"], "optional": ["any"] }
            },
            "to": [{ "key_code": "o", "modifiers": ["left_command", "left_shift"] }]
        },
        {
            "description": "Cmd+Shift+Q — remap to Cmd+Shift+[ (prev tab)",
            "type": "basic",
            "from": {
                "key_code": "q",
                "modifiers": { "mandatory": ["left_command", "left_shift"], "optional": ["any"] }
            },
            "to": [{ "key_code": "open_bracket", "modifiers": ["left_shift", "left_command"] }]
        },
        {
            "description": "Cmd+Shift+grave — remap to Cmd+Shift+P",
            "type": "basic",
            "from": {
                "key_code": "grave_accent_and_tilde",
                "modifiers": { "mandatory": ["left_command", "left_shift"], "optional": ["any"] }
            },
            "to": [{ "key_code": "p", "modifiers": ["left_shift", "left_command"] }]
        },
        {
            "description": "Cmd+Shift+Z — remap to Cmd+Shift+O",
            "type": "basic",
            "from": {
                "key_code": "z",
                "modifiers": { "mandatory": ["left_command", "left_shift"], "optional": ["any"] }
            },
            "to": [{ "key_code": "o", "modifiers": ["left_shift", "left_command"] }]
        },
        {
            "description": "Cmd+Shift+X — remap to Cmd+Shift+H",
            "type": "basic",
            "from": {
                "key_code": "x",
                "modifiers": { "mandatory": ["left_command", "left_shift"], "optional": ["any"] }
            },
            "to": [{ "key_code": "h", "modifiers": ["left_shift", "left_command"] }]
        },
        {
            "description": "Right Command + Left Option (simultaneous): move one word right then delete one word left",
            "type": "basic",
            "from": {
                "modifiers": { "optional": ["any"] },
                "simultaneous": [
                    { "key_code": "right_command" },
                    { "key_code": "left_option" }
                ]
            },
            "to": [
                { "key_code": "right_arrow", "modifiers": ["left_option"] },
                { "key_code": "delete_or_backspace", "modifiers": ["left_option"] }
            ]
        }
    ]
}

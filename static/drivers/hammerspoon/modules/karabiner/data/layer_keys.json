{
    "description": "Navigation layer — key mappings active when layer_active == 1",
    "manipulators": [
        {
            "description": "LEFT HAND - Top row: Q — Select to beginning of document",
            "conditions": [{ "name": "layer_active", "type": "variable_if", "value": 1 }],
            "from": { "key_code": "q", "modifiers": { "optional": ["any"] } },
            "to": [{ "key_code": "up_arrow", "modifiers": ["command", "shift"] }],
            "type": "basic"
        },
        {
            "description": "LEFT HAND - Top row: W — Go to beginning of document",
            "conditions": [{ "name": "layer_active", "type": "variable_if", "value": 1 }],
            "from": { "key_code": "w", "modifiers": { "optional": ["any"] } },
            "to": [{ "key_code": "up_arrow", "modifiers": ["command"] }],
            "type": "basic"
        },
        {
            "description": "LEFT HAND - Top row: E — Go to end of document",
            "conditions": [{ "name": "layer_active", "type": "variable_if", "value": 1 }],
            "from": { "key_code": "e", "modifiers": { "optional": ["any"] } },
            "to": [{ "key_code": "down_arrow", "modifiers": ["command"] }],
            "type": "basic"
        },
        {
            "description": "LEFT HAND - Top row: R — Select to end of document",
            "conditions": [{ "name": "layer_active", "type": "variable_if", "value": 1 }],
            "from": { "key_code": "r", "modifiers": { "optional": ["any"] } },
            "to": [{ "key_code": "down_arrow", "modifiers": ["command", "shift"] }],
            "type": "basic"
        },
        {
            "description": "LEFT HAND - Top row: T — F2",
            "conditions": [{ "name": "layer_active", "type": "variable_if", "value": 1 }],
            "from": { "key_code": "t", "modifiers": { "optional": ["any"] } },
            "to": [{ "key_code": "f2" }],
            "type": "basic"
        },
        {
            "description": "LEFT HAND - Middle row: A — Select paragraph up",

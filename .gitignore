# OS generated files
.DS_Store

# NPM and SvelteKit files
node_modules
/.svelte-kit
/package
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
/build/

# Python files
__pycache__
.env
.env.*
!.env.example

# Other files to exclude
logs/
*.log
static/corpus/modifie/
static/version.json
version.json

# Personal configuration files
.claude/settings.local.json
static/drivers/autohotkey/personal.ahk
# Bootstrap file is machine-specific (contains absolute path to user's ini)
static/drivers/autohotkey/ErgoptiPlus_Bootstrap.ini
# Default ini location — user-specific, never committed
static/drivers/autohotkey/ErgoptiPlus_Configuration.ini
static/drivers/hammerspoon/config.json
static/drivers/hammerspoon/karabiner_user_config.json
# Karabiner build artifact — generated at runtime by the HS bridge
static/drivers/hammerspoon/karabiner.json
# Bootstrap file — machine-specific absolute paths, never committed
static/drivers/hammerspoon/ergopti_bootstrap.json
static/drivers/hotstrings/personal.toml
static/drivers/hotstrings/personal_info.toml

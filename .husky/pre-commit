#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run AHk cleanup
npm run clean-ahk

# Update "Last modified on" date in ErgoptiPlus.ahk (cross-platform via Node.js)
node scripts/update-ahk-date.js

# Stage any changes made by the cleanup and the date update
git add static/drivers/autohotkey/*.ahk
